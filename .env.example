# Información de la aplicación
APP_NAME=SyncSentinel
APP_ENV=production

# Configuración de horarios (formato HH:MM)
MONITOR_START_TIME=18:30
VALIDATION_START_TIME=19:00
MONITOR_END_TIME=05:00
CHECK_INTERVAL_SECONDS=180

# Credenciales SQL Server (usando autenticación SQL)
MSSQL_USER=YOUR_SQL_USER
MSSQL_PASS=YOUR_SQL_PASSWORD

# Hosts de los nodos SQL Server
HOST_GAINS=192.168.3.66
HOST_REPLICA=192.168.3.83
HOST_EPICOR=192.168.3.72
HOST_CL=192.168.20.19

# Bases de datos de los nodos SQL Server
MSSQL_DB_GAINS=GAINS
MSSQL_DB_REPLICA=ReplicaDB
MSSQL_DB_EPICOR=EpicorDB
MSSQL_DB_CL=CLDB

# Configuración PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=db_metrics

# Notificaciones
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TU/WEBHOOK/URL

# Configuración de fechas para queries
START_DATE_DAYS_BACK=30
